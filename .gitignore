node_modules/
dist/
.DS_Store
*.log

# Repo-local scratchpad: ignore everything except its README
tmp/*
!tmp/README.md
kami-kakushi-itch.zip

# raw Workflow-output JSON snapshots — too large to keep tracked (kept on disk)
project/brainstorms/raw/*.json

# Playwright MCP scratch (screenshots/snapshots from live verification runs)
.playwright-mcp/

# Mobile e2e lane artifacts (traces/reports on failure — local + CI only)
playwright-report/

# QA screenshots: only the live gallery (screens/latest/) is tracked. All other
# sweep/gallery folders stay local-only — full-res PNGs bloated git to 150MB+.
# Capture into latest/; graduate a curated few elsewhere by force-add if needed.
project/audit/screens/*
!project/audit/screens/latest/

# Playtest-capture screenshots (F3): the .png sidecars are local-only viewing aids —
# the note + save-JSON .md is the committed durable record (the save reproduces the
# moment pixel-perfectly). Keep every capture's PNG out of git (human call 2026-07-04).
project/playtest-inbox/**/*.png

#!/usr/bin/env bash
# pre-push (op-model v2 — 2026-06-29):
#   1. HARD GATE — block a push to `main` if `npm run verify` is RED. pre-commit already gates
#      verify, but its SKIP_VERIFY=1 escape (used for intentional-WIP / audit checkpoints) lets a
#      red commit sit on local main. main is the published branch (gh-pages deploys from it), so it
#      must never go red on the remote. This is the backstop net: green-or-it-doesn't-push. A gate
#      beats a good intention (CLAUDE.md). Scoped to main — feature branches and the gh-pages site
#      push are NOT gated.
#   2. SOFT READOUT — surface verify-budget DRIFT loudly but NEVER block (the X-3 "noisy, not
#      blocking" half). The HARD budget check is the explicit `npm run verify:budget`.
#
# Bypass:  SKIP_VERIFY=1 git push   (skip the hard main gate — deliberate red push, emergencies only)
#          SKIP_BUDGET=1 git push   (skip the budget readout)
# Enable once per clone:  git config core.hooksPath .githooks

set -uo pipefail

# --- 1. HARD GATE: verify must be green to push main ------------------------------------------
# Pre-push passes "<local ref> <local sha> <remote ref> <remote sha>" lines on stdin. Detect a
# push that updates refs/heads/main on the remote (skip branch deletes — all-zero local sha).
ZERO="0000000000000000000000000000000000000000"
pushing_main=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ] && [ "$local_sha" != "$ZERO" ]; then
    pushing_main=1
  fi
done

if [ "$pushing_main" = "1" ] && [ "${SKIP_VERIFY:-0}" != "1" ]; then
  echo "  - pre-push: verify must be GREEN to push main…" >&2
  if ! npm run --silent verify >&2; then
    echo "" >&2
    echo "  ✗ BLOCKED: verify is RED — refusing to push main." >&2
    echo "    Fix it, or 'SKIP_VERIFY=1 git push' to override (deliberate red push only)." >&2
    exit 1
  fi
fi

# --- 2. SOFT READOUT: budget drift (never blocks) --------------------------------------------
if [ "${SKIP_BUDGET:-0}" = "1" ]; then
  exit 0
fi

echo "  - pre-push: verify-budget readout (non-blocking; SKIP_BUDGET=1 to skip)…" >&2
if ! npm run --silent verify:budget >&2; then
  echo "" >&2
  echo "  !! verify is OVER its time budget (or red). NOT blocking the push — but worth a look:" >&2
  echo "     'npm run verify:budget' for the per-gate breakdown." >&2
fi

exit 0

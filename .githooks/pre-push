#!/usr/bin/env bash
# pre-push: run the full verify on EVERY push (all branches) and block if it's RED.
# The build must be green to leave the machine. Simple and unconditional.
#
# Bypass:  SKIP_VERIFY=1 git push   (emergencies / deliberate red push only)
# NB: the commit-time lane flags (SKIP_CODE_VERIFY / SKIP_DOCS_VERIFY) are deliberately
# UNSET here — a push always verifies the FULL roster, even if a shell exports them.
# Enable once per clone:  git config core.hooksPath .githooks

set -uo pipefail

if [ "${SKIP_VERIFY:-0}" = "1" ]; then
  echo "  - SKIP_VERIFY=1 -> pre-push verify skipped" >&2
  exit 0
fi

# herdr advisory (optional; clean no-op without herdr): if other agents share this
# working tree, name them so a verify RED you did NOT cause is legible, not
# mysterious. Advisory only — never changes the push outcome (D-124; advisory rung).
if [ "${SKIP_HERDR_PEERS:-0}" != "1" ]; then
  _peers="$(bash "$(git rev-parse --show-toplevel 2>/dev/null || pwd)/src/scripts/herdr-peers.sh" 2>/dev/null || true)"
  if [ -n "$_peers" ]; then
    echo "  - herdr: other agents share this tree — a RED below may be THEIR WIP, not yours:" >&2
    printf '%s\n' "$_peers" | while IFS="$(printf '\t')" read -r _pane _status _goal; do
      [ -n "$_pane" ] || continue
      if [ -n "$_goal" ]; then echo "      $_pane ($_status) — $_goal" >&2; else echo "      $_pane ($_status)" >&2; fi
    done
  fi
fi

echo "  - pre-push: verify must be GREEN to push…" >&2
if ! env -u SKIP_CODE_VERIFY -u SKIP_DOCS_VERIFY npm run --silent verify >&2; then
  echo "" >&2
  echo "  ✗ BLOCKED: verify is RED — refusing to push." >&2
  echo "    Fix it, or 'SKIP_VERIFY=1 git push' to override (emergencies only)." >&2
  exit 1
fi

exit 0

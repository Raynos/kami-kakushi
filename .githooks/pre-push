#!/usr/bin/env bash
# pre-push: run the full verify on EVERY push (all branches) and block if it's RED.
# The build must be green to leave the machine. Simple and unconditional.
#
# Bypass:  SKIP_VERIFY=1 git push   (emergencies / deliberate red push only)
# NB: the commit-time lane flags (SKIP_CODE_VERIFY / SKIP_DOCS_VERIFY) are deliberately
# UNSET here — a push always verifies the FULL roster, even if a shell exports them.
# Enable once per clone:  git config core.hooksPath .githooks

set -uo pipefail

# Capture the ref lines git feeds on stdin (<local ref> <local sha> <remote ref>
# <remote sha>) BEFORE verify runs — used by the e2e blast-radius advisory below.
_push_refs="$(cat)"

if [ "${SKIP_VERIFY:-0}" = "1" ]; then
  echo "  - SKIP_VERIFY=1 -> pre-push verify skipped" >&2
  exit 0
fi

# herdr advisory (optional; clean no-op without herdr): if other agents share this
# working tree, name them so a verify RED you did NOT cause is legible, not
# mysterious. Advisory only — never changes the push outcome (D-124; advisory rung).
if [ "${SKIP_HERDR_PEERS:-0}" != "1" ]; then
  _peers="$(bash "$(git rev-parse --show-toplevel 2>/dev/null || pwd)/src/scripts/herdr-peers.sh" 2>/dev/null || true)"
  if [ -n "$_peers" ]; then
    echo "  - herdr: other agents share this tree — a RED below may be THEIR WIP, not yours:" >&2
    printf '%s\n' "$_peers" | while IFS="$(printf '\t')" read -r _pane _status _goal; do
      [ -n "$_pane" ] || continue
      if [ -n "$_goal" ]; then echo "      $_pane ($_status) — $_goal" >&2; else echo "      $_pane ($_status)" >&2; fi
    done
  fi
fi

echo "  - pre-push: FULL verify (incl. @slow full-arc tests) must be GREEN to push…" >&2
if ! env -u SKIP_CODE_VERIFY -u SKIP_DOCS_VERIFY VERIFY_FULL=1 pnpm run --silent verify >&2; then
  echo "" >&2
  echo "  ✗ BLOCKED: verify is RED — refusing to push." >&2
  echo "    Fix it, or 'SKIP_VERIFY=1 git push' to override (emergencies only)." >&2
  exit 1
fi

# e2e blast-radius advisory (loud warn, NEVER blocks): the Playwright e2e lane
# (`pnpm run test:e2e`) gates only in CI (e2e.yml) — it's far past verify's 5s
# budget (D-072), so no local hook runs it. When the pushed commits touch the
# lane's covered surface, name the files and nudge a local run now, instead of
# a red e2e.yml surfacing minutes after the push. Silence: SKIP_E2E_WARN=1.
if [ "${SKIP_E2E_WARN:-0}" != "1" ] && [ -n "$_push_refs" ]; then
  _e2e_paths='^src/tests/e2e/|^playwright\.config\.ts$|^src/fixtures/|^src/ui/styles\.css$'
  _pushed_files=""
  while read -r _lref _lsha _rref _rsha; do
    [ -n "${_lsha:-}" ] || continue
    case "$_lsha" in *[!0]*) ;; *) continue ;; esac  # all-zero sha = ref delete
    case "$_rsha" in
      *[!0]*) _base="$_rsha" ;;  # existing remote ref: diff what's new to it
      *) _base="$(git merge-base "$_lsha" origin/main 2>/dev/null || true)" ;;  # new ref
    esac
    [ -n "$_base" ] || continue
    _pushed_files="$_pushed_files
$(git diff --name-only "$_base" "$_lsha" 2>/dev/null)"
  done <<< "$_push_refs"
  _e2e_touched="$(printf '%s\n' "$_pushed_files" | grep -E "$_e2e_paths" | sort -u || true)"
  if [ -n "$_e2e_touched" ]; then
    echo "" >&2
    echo "  ⚠ e2e blast radius — this push touches the e2e-covered surface:" >&2
    printf '%s\n' "$_e2e_touched" | sed 's/^/      /' >&2
    echo "    The Playwright lane is CI-only (D-072); consider a local" >&2
    echo "    'pnpm run test:e2e' (~50s) now rather than a red e2e.yml after the" >&2
    echo "    push lands. Advisory only — pushing anyway. (SKIP_E2E_WARN=1 hides this.)" >&2
  fi
fi

exit 0

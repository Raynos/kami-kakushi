#!/usr/bin/env bash
# Journal-hygiene gate: every commit must stage a change under journal/ (a new or
# updated *.md), so the build keeps a running, resumable log.
#
# Bypass a genuinely trivial commit:  SKIP_JOURNAL=1 git commit ...
# Enable once per clone:              git config core.hooksPath .githooks

if [ "${SKIP_JOURNAL:-0}" = "1" ]; then
  exit 0
fi

if git diff --cached --name-only --diff-filter=ACMR | grep -qE '^journal/.*\.md$'; then
  exit 0
fi

cat >&2 <<'MSG'

  ✗ commit blocked — no journal entry staged.

  Record what this commit does in journal/ (append to the current session log or add a
  checkpoint file), then stage it and commit again.

  Trivial commit? Bypass with:  SKIP_JOURNAL=1 git commit ...

MSG
exit 1

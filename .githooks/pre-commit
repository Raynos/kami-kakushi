#!/usr/bin/env bash
# Pre-commit gate (op-model v2 FINAL, Workstreams A+B — 2026-06-29):
#   1. Run the FULL `npm run verify` (~3s measured) so a commit can never be red.
#      verify = tsc + eslint + prettier + vitest + verify-content + gen:docs --check + pacing:check.
#   2. Wrap it in a soft 5s-budget DRIFT timer: green (<4s) silent · amber (4–5s) note ·
#      red (>5s) loud nudge — but NEVER block on time (a slow machine must not fail a commit).
#      Every run appends a row to tmp/precommit-timings.tsv so drift is a readable curve.
#   3. Reading-queue gate: a brand-NEW docs/plans/*.md must be listed in project/todo-human.md (HARD
#      block); a new brainstorm / audit report not listed is a LOUD WARN (judgment dirs). So a doc meant
#      for the human can't silently miss their reading queue. See CLAUDE.md "Reading queue".
#   4. Journal-hygiene gate (unchanged).
# The HARD budget check is the explicit `npm run verify:budget`; the pre-push hook surfaces it
# loudly-but-non-blocking. Principle (X-3): noisy about drift, never blocking the task in flight.
#
# Bypass:  SKIP_VERIFY=1  git commit …   (docs-only/trivial: skip the verify gate)
#          SKIP_JOURNAL=1 git commit …   (skip the journal gate)
#          SKIP_QUEUE=1   git commit …   (skip the reading-queue gate: a new plan genuinely not for the human)
# Enable once per clone:  git config core.hooksPath .githooks

set -uo pipefail

BUDGET_S="${PRECOMMIT_BUDGET_S:-5}"   # soft drift budget (seconds)
AMBER_S="${PRECOMMIT_AMBER_S:-4}"     # warn when approaching the budget

run_verify() {
  if [ "${SKIP_VERIFY:-0}" = "1" ]; then
    echo "  - SKIP_VERIFY=1 -> full verify skipped" >&2
    return 0
  fi

  echo "  - npm run verify (full gate; SKIP_VERIFY=1 to bypass a docs-only commit)…" >&2
  local start end elapsed
  start=$(date +%s)
  if ! npm run --silent verify >&2; then
    echo "" >&2
    echo "  X commit blocked - verify failed. Fix it, or SKIP_VERIFY=1 for a docs-only commit." >&2
    return 1
  fi
  end=$(date +%s)
  elapsed=$((end - start))

  # --- drift timer: NOISY, never blocks on time (X-3) ---
  local loc=0 tests=0
  local srcfiles=()
  while IFS= read -r f; do [ -n "$f" ] && srcfiles+=("$f"); done \
    < <(git ls-files src | grep -E '\.ts$' | grep -vE '\.test\.ts$' || true)
  if [ "${#srcfiles[@]}" -gt 0 ]; then
    loc=$(cat "${srcfiles[@]}" 2>/dev/null | wc -l | tr -d ' ')
  fi
  tests=$(grep -rhoE "\b(it|test)\(" src --include='*.test.ts' 2>/dev/null | wc -l | tr -d ' ')
  printf '%s\t%s\t%s\t%s\n' "$(date +%s)" "$elapsed" "$loc" "$tests" >> tmp/precommit-timings.tsv 2>/dev/null || true

  if [ "$elapsed" -gt "$BUDGET_S" ]; then
    echo "  !! verify took ${elapsed}s - OVER the ${BUDGET_S}s budget. Worth trimming/speeding the gate when" >&2
    echo "     you get a chance: run 'npm run verify:budget' for the per-gate breakdown. (NOT blocking this commit.)" >&2
  elif [ "$elapsed" -ge "$AMBER_S" ]; then
    echo "  ~ verify took ${elapsed}s - approaching the ${BUDGET_S}s budget." >&2
  fi
  return 0
}

if ! run_verify; then
  echo "" >&2
  echo "  commit blocked by verify (bypass a docs-only commit: SKIP_VERIFY=1 git commit …)" >&2
  exit 1
fi

# --- PRD-drift nudge (D-117 Phase 0 — WARN ONLY, never blocks): a commit that touches the content
#     registries (src/core/content/*, where display names live) without touching the PRD may have
#     staled a spec fact — `npm run prd:drift` prints the punch-list. balance.ts is EXCLUDED: it
#     holds magnitudes, and §4's magnitudes are deliberately ripple-frozen (D-117 interim rule),
#     so nudging a PRD edit there would push AGAINST canon. Report-only tool, warn-only rung (A11). ---
staged_all="$(git diff --cached --name-only)"
if echo "$staged_all" | grep -vE '^src/core/content/balance\.ts$' | grep -qE '^src/core/content/' \
  && ! echo "$staged_all" | grep -qE '^docs/living/prd/'; then
  echo "  ~ content registries changed without a PRD touch — if a display name / roster moved," >&2
  echo "    run 'npm run prd:drift' for the game->PRD punch-list (report-only; D-117 Flow 1)." >&2
fi

# --- Reading-queue gate: a durable doc whose PURPOSE is the human reading / reviewing / signing off on
#     it must be listed in the reading queue (project/todo-human.md) in the SAME commit, or it silently
#     never reaches the human (the bug this fixes). Fires on brand-NEW files only — editing or archiving
#     an existing doc never trips it. Two rungs, placed only as high as each path can SOUNDLY hold (the
#     queue's own history is the evidence — see CLAUDE.md "Reading queue"):
#       • docs/plans/*.md  -> HARD BLOCK  (queue-membership is ~universal here -> a true gate, no wolf-crying;
#         docs/plans/README.md is exempt -> it documents the dir, it's never a for-the-human plan)
#       • project/brainstorms/*.md, project/audit/reports/*.md  -> LOUD WARN  (judgment dirs: most aren't
#         for the human, so blocking would train reflexive bypassing -> alarm fatigue -> drops return)
#     The CLAUDE.md rule is the judgment-based backstop for EVERY other path. We verify the exact path is
#     present in the to-be-committed queue, so touching todo-human.md for an unrelated reason can't fool it.
#     Bypass the whole gate (rare — e.g. a plan added then immediately archived):  SKIP_QUEUE=1 git commit … ---
if [ "${SKIP_QUEUE:-0}" != "1" ]; then
  added_files="$(git diff --cached --name-only --diff-filter=A)"
  queue_now="$(git show :project/todo-human.md 2>/dev/null || true)"   # the to-be-committed queue (index blob)
  unqueued_plans=""
  unqueued_soft=""
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
      docs/plans/README.md)
        : ;;  # the dir's own README documents the convention; never a for-the-human plan
      docs/plans/*.md)
        grep -Fq "$f" <<<"$queue_now" || unqueued_plans="${unqueued_plans}    - ${f}"$'\n' ;;
      project/brainstorms/*.md|project/audit/reports/*.md)
        grep -Fq "$f" <<<"$queue_now" || unqueued_soft="${unqueued_soft}    - ${f}"$'\n' ;;
    esac
  done <<<"$added_files"
  if [ -n "$unqueued_plans" ]; then
    {
      echo ""
      echo "  X commit blocked - NEW plan(s) not listed in the reading queue (project/todo-human.md):"
      printf '%s' "$unqueued_plans"
      echo ""
      echo "  A docs/plans/ doc awaits the human's read & sign-off, so it MUST appear under '## Reading"
      echo "  queue' in project/todo-human.md (same commit) - else the human never sees it. Add the line,"
      echo "  stage project/todo-human.md, commit again."
      echo ""
      echo "  Genuinely not for the human (rare)?  SKIP_QUEUE=1 git commit ..."
      echo ""
    } >&2
    exit 1
  fi
  if [ -n "$unqueued_soft" ]; then
    {
      echo ""
      echo "  !! reading-queue WARN (NOT blocking) - NEW review-worthy doc(s) not in project/todo-human.md:"
      printf '%s' "$unqueued_soft"
      echo "     If the human should READ it, add it under '## Reading queue' now - else it's invisible to them."
      echo "     Raw discovery / agent-internal notes: ignore this. (CLAUDE.md 'Reading queue' has the rule.)"
      echo ""
    } >&2
  fi
fi

# --- Snapshot-shape gate: project/status/project-status.md is the LIVE one-screen SNAPSHOT
#     (overwrite-in-place), NOT an append-only log — appending per-session history is the journal's
#     job. It silently drifted to 326 lines of dated "Phase update — (session-NN)" bullets once,
#     because a norm ("keep this to one screen") with nothing measuring it is a norm that gets
#     ignored. So escalate a rung to a gate. Two checks on the to-be-committed blob (the index, so
#     touching the file for an unrelated reason still gets checked):
#       • line count > SNAPSHOT_MAX_LINES (default 120) -> HARD BLOCK. Objective + a real snapshot is
#         ~90 lines, so 120 is generous headroom that never cries wolf — but 326 is impossible.
#       • a "- **Phase update …" bullet (the journal-genre signature) -> LOUD WARN -> move it to journal/.
#     Bypass (rare — a deliberate, human-blessed cap raise):  SKIP_SNAPSHOT=1 git commit … ---
SNAPSHOT_FILE="project/status/project-status.md"
if [ "${SKIP_SNAPSHOT:-0}" != "1" ] \
  && git diff --cached --name-only --diff-filter=ACMR | grep -Fxq "$SNAPSHOT_FILE"; then
  SNAPSHOT_MAX_LINES="${SNAPSHOT_MAX_LINES:-120}"
  snap="$(git show ":${SNAPSHOT_FILE}" 2>/dev/null || true)"
  snap_lines="$(printf '%s' "$snap" | grep -c '' || true)"
  if [ "$snap_lines" -gt "$SNAPSHOT_MAX_LINES" ]; then
    {
      echo ""
      echo "  X commit blocked - ${SNAPSHOT_FILE} is ${snap_lines} lines (cap ${SNAPSHOT_MAX_LINES})."
      echo ""
      echo "  This file is the LIVE ONE-SCREEN SNAPSHOT - overwrite it in place, do NOT append. The"
      echo "  lossless 'how it got here' record is project/journal/, so trim/replace stale state here"
      echo "  (it survives in the journal). Move any dated 'Phase update' history into the session journal."
      echo ""
      echo "  Genuinely need the headroom?  SKIP_SNAPSHOT=1 git commit ...  (raise the cap on purpose)"
      echo ""
    } >&2
    exit 1
  fi
  if printf '%s\n' "$snap" | grep -qE '^[[:space:]]*-[[:space:]]+\*\*Phase update'; then
    {
      echo ""
      echo "  !! snapshot WARN (NOT blocking) - ${SNAPSHOT_FILE} has a dated 'Phase update -' bullet."
      echo "     That's the JOURNAL genre leaking into the snapshot - per-session history belongs in"
      echo "     project/journal/. Keep this file a current-state snapshot (see its header)."
      echo ""
    } >&2
  fi
fi

# --- Journal-hygiene gate (policy UNCHANGED): every commit stages a journal/ entry so the build
#     keeps a running, resumable log. Live state lives in project/status/project-status.md. ---
if [ "${SKIP_JOURNAL:-0}" = "1" ]; then
  exit 0
fi

# NB: capture into a var, then match via a here-string — NOT a pipe into `grep -q`. Under
# `set -o pipefail`, grep -q closes the read end on first match, and a large producer (thousands of
# staged files) gets SIGPIPE (exit 141) → the pipeline reports non-zero even though the journal entry
# matched, falsely blocking a valid commit. A here-string has no pipe producer to signal.
staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"
if grep -qE '^project/journal/.*\.md$' <<<"$staged_files"; then
  echo "  - journal staged - convention: summary at TOP, APPEND entries at the BOTTOM (never prepend); live state -> project/status/project-status.md (see project/journal/README.md)" >&2
  exit 0
fi

cat >&2 <<'MSG'

  X commit blocked - no journal entry staged.

  Record what this commit does in journal/ (append to the current session log or add a
  checkpoint file), then stage it and commit again.

  JOURNAL CONVENTION (project/journal/README.md): the journal is a chronological LOG, not a live
  snapshot. Summary at the TOP; APPEND new entries at the BOTTOM (oldest->newest, never
  prepend); no stale "current state" block (that lives in project/status/project-status.md).

  Trivial commit? Bypass with:  SKIP_JOURNAL=1 git commit ...

MSG
exit 1

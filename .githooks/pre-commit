#!/usr/bin/env bash
# Pre-commit gate (op-model v2 FINAL, Workstreams A+B — 2026-06-29):
#   1. Run the FULL `pnpm run verify` (~5s measured) so a commit can never be red.
#      The gate roster is owned by src/scripts/gates.ts (the single source — do NOT
#      re-list it here; that copy drifted). `pnpm run checkpoint` regenerates the
#      human-facing roster docs from it.
#   2. Wrap it in a soft 5s-budget DRIFT timer: green (<4s) silent · amber (4–5s) note ·
#      red (>5s) loud nudge — but NEVER block on time (a slow machine must not fail a commit).
#      Every run appends a row to tmp/precommit-timings.tsv so drift is a readable curve.
#   3. Reading-queue gate: a brand-NEW docs/plans/*.md must be listed in project/todo-human.md (HARD
#      block); a new brainstorm / audit report not listed is a LOUD WARN (judgment dirs). So a doc meant
#      for the human can't silently miss their reading queue. See CLAUDE.md "Reading queue".
#   4. Journal-hygiene gate (unchanged).
# The HARD budget check is the explicit `pnpm run verify:budget`; the pre-push hook surfaces it
# loudly-but-non-blocking. Principle (X-3): noisy about drift, never blocking the task in flight.
#
# Bypass:  SKIP_CODE_VERIFY=1 git commit …  (docs-only commit: skip the code gates, docs gates STILL run — ~1s)
#          SKIP_DOCS_VERIFY=1 git commit …  (pure-code commit: skip the docs-lane gates)
#          SKIP_VERIFY=1  git commit …   (skip the WHOLE verify — last resort; prefer the lane flags above)
#          SKIP_JOURNAL=1 git commit …   (skip the journal gate)
#          SKIP_QUEUE=1   git commit …   (skip the reading-queue gate: a new plan genuinely not for the human)
# Lane semantics live in src/scripts/verify-run.ts + verify-scope.ts (the flags pass through env).
# Enable once per clone:  git config core.hooksPath .githooks

set -uo pipefail

BUDGET_S="${PRECOMMIT_BUDGET_S:-5}"   # soft drift budget (seconds)
AMBER_S="${PRECOMMIT_AMBER_S:-4}"     # warn when approaching the budget

run_verify() {
  if [ "${SKIP_VERIFY:-0}" = "1" ]; then
    echo "  - SKIP_VERIFY=1 -> full verify skipped" >&2
    return 0
  fi

  echo "  - pnpm run verify (docs-only commit? SKIP_CODE_VERIFY=1 keeps the docs gates + skips the slow lane)…" >&2
  local start end elapsed
  start=$(date +%s)
  if ! pnpm run --silent verify >&2; then
    echo "" >&2
    echo "  X commit blocked - verify failed. Fix it; a docs-only commit can SKIP_CODE_VERIFY=1" >&2
    echo "    (docs gates still run). SKIP_VERIFY=1 skips everything - last resort." >&2
    return 1
  fi
  end=$(date +%s)
  elapsed=$((end - start))

  # --- drift timer: NOISY, never blocks on time (X-3) ---
  local loc=0 tests=0
  local srcfiles=()
  while IFS= read -r f; do [ -n "$f" ] && srcfiles+=("$f"); done \
    < <(git ls-files src | grep -E '\.ts$' | grep -vE '\.test\.ts$' || true)
  if [ "${#srcfiles[@]}" -gt 0 ]; then
    loc=$(cat "${srcfiles[@]}" 2>/dev/null | wc -l | tr -d ' ')
  fi
  tests=$(grep -rhoE "\b(it|test)\(" src --include='*.test.ts' 2>/dev/null | wc -l | tr -d ' ')
  printf '%s\t%s\t%s\t%s\n' "$(date +%s)" "$elapsed" "$loc" "$tests" >> tmp/precommit-timings.tsv 2>/dev/null || true

  if [ "$elapsed" -gt "$BUDGET_S" ]; then
    echo "  !! verify took ${elapsed}s - OVER the ${BUDGET_S}s budget. Worth trimming/speeding the gate when" >&2
    echo "     you get a chance: run 'pnpm run verify:budget' for the per-gate breakdown. (NOT blocking this commit.)" >&2
  elif [ "$elapsed" -ge "$AMBER_S" ]; then
    echo "  ~ verify took ${elapsed}s - approaching the ${BUDGET_S}s budget." >&2
  fi
  return 0
}

# --- Staged-set echo (sweep visibility): the index is SHARED across agents — print exactly
#     what THIS commit will contain, so a swept-in co-agent file is loud, not silent. Under a
#     pathspec commit (git commit … -- paths) this reflects the temp index = only your paths. ---
echo "  - staged for THIS commit:" >&2
git diff --cached --name-only | sed 's/^/      /' >&2

# --- herdr peer FYI (optional; clean no-op without herdr): the index is shared, and so is
#     the working tree — remind a long-running agent WHO ELSE is live here right now, with
#     each agent's current goal. Advisory only; never blocks (D-124; advisory rung). ---
if [ "${SKIP_HERDR_PEERS:-0}" != "1" ]; then
  _peers="$(bash "$(git rev-parse --show-toplevel 2>/dev/null || pwd)/src/scripts/herdr-peers.sh" 2>/dev/null || true)"
  if [ -n "$_peers" ]; then
    _n="$(printf '%s\n' "$_peers" | grep -c .)"
    echo "  - herdr FYI: $_n other agent(s) live on this tree (stage only your paths; never 'git add -A'):" >&2
    printf '%s\n' "$_peers" | while IFS="$(printf '\t')" read -r _pane _status _goal; do
      [ -n "$_pane" ] || continue
      if [ -n "$_goal" ]; then echo "      $_pane ($_status) — $_goal" >&2; else echo "      $_pane ($_status)" >&2; fi
    done
  fi
fi

if ! run_verify; then
  echo "" >&2
  echo "  commit blocked by verify (docs-only commit: SKIP_CODE_VERIFY=1 git commit … keeps the docs gates)" >&2
  exit 1
fi

# --- PRD-drift nudge (D-117 Phase 0 — WARN ONLY, never blocks): a commit that touches the content
#     registries (src/core/content/*, where display names live) without touching the PRD may have
#     staled a spec fact — `pnpm run prd:drift` prints the punch-list. balance.ts is EXCLUDED: it
#     holds magnitudes, and §4's magnitudes are deliberately ripple-frozen (D-117 interim rule),
#     so nudging a PRD edit there would push AGAINST canon. Report-only tool, warn-only rung (A11). ---
staged_all="$(git diff --cached --name-only)"
if echo "$staged_all" | grep -vE '^src/core/content/balance\.ts$' | grep -qE '^src/core/content/' \
  && ! echo "$staged_all" | grep -qE '^docs/living/prd/'; then
  echo "  ~ content registries changed without a PRD touch — if a display name / roster moved," >&2
  echo "    run 'pnpm run prd:drift' for the game->PRD punch-list (report-only; D-117 Flow 1)." >&2
fi

# --- Balance-report freshness WARN (F4 §5b — WARN ONLY for now; promotion to a hard gate is
#     H20, decided by whether this gets ignored): a commit that touches the sim's design inputs
#     (src/core/content/*) without a regenerated docs/content/t0-pacing.md has probably staled
#     the committed pacing report. `balance-sim --check-fresh` recomputes the input FINGERPRINT
#     (evaluated values, no sim run, <1 s) vs the report header — it fires exactly on a VALUE
#     change, never on comments/formatting, so this warn can't cry wolf. Scoped to commits that
#     stage a design-input file, so every other commit pays nothing. ---
if [ "${SKIP_BALANCE_FRESH:-0}" != "1" ]; then
  if echo "$staged_all" | grep -qE '^src/core/content/'; then
    if ! pnpm exec tsx src/scripts/balance-sim.ts --check-fresh >&2; then
      echo "  !! balance WARN (NOT blocking): this commit changes design inputs but the committed" >&2
      echo "     pacing report was generated from OLDER values. Run 'pnpm run verify:balance' (the" >&2
      echo "     machine verdict) then 'pnpm run balance:report' and commit the diff WITH the change" >&2
      echo "     — the report diff IS the before/after. (F4 §5b; silence with SKIP_BALANCE_FRESH=1.)" >&2
    fi
  fi
fi

# --- Map-sheets signpost (human, 2026-07-08 — WARN ONLY, one line): editing the survey-sheet
#     engine without staging the golden pin is EITHER a look-neutral refactor (fine — the pin's
#     green run is the proof) or a forgotten regen (the vitest gate above already went RED if so).
#     Either way, point the editor at the laws once. Scoped to map-sheets code; costs nothing else. ---
if [ "${SKIP_MAP_SIGNPOST:-0}" != "1" ]; then
  if echo "$staged_all" | grep -qE '^src/ui/map-sheets/.*\.ts$' \
    && ! echo "$staged_all" | grep -qx 'src/ui/map-sheets/golden.hash.json'; then
    echo "  ~ map-sheets edited without a pin regen — fine for a look-neutral refactor (green pin =" >&2
    echo "    proof); a LOOK change must commit the regenerated hash WITH it. Laws + workflow:" >&2
    echo "    src/ui/map-sheets/README.md · docs/guides/map-authoring.md (SKIP_MAP_SIGNPOST=1 silences)." >&2
  fi
fi

# --- Reading-queue gate: a durable doc whose PURPOSE is the human reading / reviewing / signing off on
#     it must be listed in the reading queue (project/todo-human.md) in the SAME commit, or it silently
#     never reaches the human (the bug this fixes). Fires on brand-NEW files only — editing or archiving
#     an existing doc never trips it. Two rungs, placed only as high as each path can SOUNDLY hold (the
#     queue's own history is the evidence — see CLAUDE.md "Reading queue"):
#       • docs/plans/*.md  -> HARD BLOCK  (queue-membership is ~universal here -> a true gate, no wolf-crying;
#         docs/plans/README.md is exempt -> it documents the dir, it's never a for-the-human plan)
#       • project/brainstorms/*.md, project/audit/reports/*.md  -> LOUD WARN  (judgment dirs: most aren't
#         for the human, so blocking would train reflexive bypassing -> alarm fatigue -> drops return)
#     The CLAUDE.md rule is the judgment-based backstop for EVERY other path. We verify the exact path is
#     present in the to-be-committed queue, so touching todo-human.md for an unrelated reason can't fool it.
#     Bypass the whole gate (rare — e.g. a plan added then immediately archived):  SKIP_QUEUE=1 git commit … ---
if [ "${SKIP_QUEUE:-0}" != "1" ]; then
  added_files="$(git diff --cached --name-only --diff-filter=A)"
  queue_now="$(git show :project/todo-human.md 2>/dev/null || true)"   # the to-be-committed queue (index blob)
  unqueued_plans=""
  unqueued_soft=""
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
      docs/plans/README.md)
        : ;;  # the dir's own README documents the convention; never a for-the-human plan
      docs/plans/*.md)
        grep -Fq "$f" <<<"$queue_now" || unqueued_plans="${unqueued_plans}    - ${f}"$'\n'
        # Model-prefix convention (human, 2026-07-03): plan filenames carry the AUTHORING
        # session's model — fable-/opus-… (see docs/plans/README.md). WARN-only rung.
        case "$(basename "$f")" in
          fable-*|opus-*|sonnet-*|haiku-*) : ;;
          *) echo "  ~ new plan '$f' lacks a model prefix (fable-/opus-…) — name it <model>-<date>-<slug>.md (docs/plans/README.md)" >&2 ;;
        esac ;;
      project/brainstorms/*.md|project/audit/reports/*.md)
        grep -Fq "$f" <<<"$queue_now" || unqueued_soft="${unqueued_soft}    - ${f}"$'\n' ;;
    esac
  done <<<"$added_files"
  if [ -n "$unqueued_plans" ]; then
    {
      echo ""
      echo "  X commit blocked - NEW plan(s) not listed in the reading queue (project/todo-human.md):"
      printf '%s' "$unqueued_plans"
      echo ""
      echo "  A docs/plans/ doc awaits the human's read & sign-off, so it MUST appear under '## Reading"
      echo "  queue' in project/todo-human.md (same commit) - else the human never sees it. Add the line,"
      echo "  stage project/todo-human.md, commit again."
      echo ""
      echo "  Genuinely not for the human (rare)?  SKIP_QUEUE=1 git commit ..."
      echo ""
    } >&2
    exit 1
  fi
  if [ -n "$unqueued_soft" ]; then
    {
      echo ""
      echo "  !! reading-queue WARN (NOT blocking) - NEW review-worthy doc(s) not in project/todo-human.md:"
      printf '%s' "$unqueued_soft"
      echo "     If the human should READ it, add it under '## Reading queue' now - else it's invisible to them."
      echo "     Raw discovery / agent-internal notes: ignore this. (CLAUDE.md 'Reading queue' has the rule.)"
      echo ""
    } >&2
  fi
fi

# --- Human-TODO ownership gate (human, 2026-07-06 — HARD BLOCK): the '## TODO' section of
#     project/todo-human.md is the HUMAN's list — tasks only they can do, authored by them.
#     An agent surfacing a finding/question files it in project/human-in-the-loop/
#     (H-decision or R-review), NEVER as a TODO line (the s88 mistake this gate tombstones).
#     Fires only when a commit ADDS a checkbox line inside '## TODO' (edits to the Reading
#     queue section — which the reading-queue gate REQUIRES — never trip it; neither does
#     removing/ticking lines). Sound at the block rung: ~every commit here is agent-made.
#     The human dictating an addition is the one bypass:  SKIP_HUMAN_TODO=1 git commit … ---
if [ "${SKIP_HUMAN_TODO:-0}" != "1" ]; then
  if git diff --cached --name-only | grep -qx 'project/todo-human.md'; then
    _todo_section() { sed -n '/^## TODO/,/^## Reading queue/p' | grep -E '^- \[' || true; }
    _head_todos="$(git show HEAD:project/todo-human.md 2>/dev/null | _todo_section)"
    _staged_todos="$(git show :project/todo-human.md 2>/dev/null | _todo_section)"
    _new_todos="$(comm -13 <(printf '%s\n' "$_head_todos" | sort -u) \
                           <(printf '%s\n' "$_staged_todos" | sort -u) | grep -E '^- \[' || true)"
    if [ -n "$_new_todos" ]; then
      {
        echo ""
        echo "  X commit blocked - new line(s) under '## TODO' in project/todo-human.md:"
        printf '%s\n' "$_new_todos" | sed 's/^/      /'
        echo ""
        echo "  That section is the HUMAN's own list - agents never append to it. File the item in"
        echo "  project/human-in-the-loop/ instead: a design fork/question -> decisions.md (HD-item),"
        echo "  a look/feel/taste check -> review.md (HR-item). The session brief surfaces both."
        echo ""
        echo "  Human dictated this TODO to you verbatim?  SKIP_HUMAN_TODO=1 git commit ..."
        echo ""
      } >&2
      exit 1
    fi
  fi
fi

# --- Doc-budget gate (D-126, absorbs the old snapshot-shape gate): snapshot-class docs
#     (project-status 120 · taste.md 150 · ui-design.md 400) hold HARD line caps + genre warns.
#     The caps live in ONE place: src/scripts/verify-doc-budgets.ts, a docs-lane verify gate —
#     so it already ran inside run_verify above (SKIP_CODE_VERIFY keeps the docs lane). Only a
#     full SKIP_VERIFY=1 skips it there, so re-invoke standalone in that case — docs-only
#     commits are exactly when the caps matter. Bypass (a deliberate, human-blessed cap
#     raise ONLY):  SKIP_DOCBUDGET=1 git commit … ---
if [ "${SKIP_VERIFY:-0}" = "1" ] && [ "${SKIP_DOCBUDGET:-0}" != "1" ]; then
  if ! pnpm exec tsx src/scripts/verify-doc-budgets.ts >&2; then
    echo "" >&2
    echo "  X commit blocked - a snapshot-class doc is over its hard cap. Cull, don't bypass" >&2
    echo "    (SKIP_DOCBUDGET=1 is for a human-blessed cap raise only)." >&2
    exit 1
  fi
fi

# --- Journal-hygiene gate (policy UNCHANGED): every commit stages a journal/ entry so the build
#     keeps a running, resumable log. Live state lives in project/status/project-status.md. ---
if [ "${SKIP_JOURNAL:-0}" = "1" ]; then
  exit 0
fi

# NB: capture into a var, then match via a here-string — NOT a pipe into `grep -q`. Under
# `set -o pipefail`, grep -q closes the read end on first match, and a large producer (thousands of
# staged files) gets SIGPIPE (exit 141) → the pipeline reports non-zero even though the journal entry
# matched, falsely blocking a valid commit. A here-string has no pipe producer to signal.
staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"
if grep -qE '^project/journal/.*\.md$' <<<"$staged_files"; then
  echo "  - journal staged - convention: summary at TOP, APPEND entries at the BOTTOM (never prepend); live state -> project/status/project-status.md (see project/journal/README.md)" >&2
  exit 0
fi

cat >&2 <<'MSG'

  X commit blocked - no journal entry staged.

  Record what this commit does in journal/ (append to the current session log or add a
  checkpoint file), then stage it and commit again.

  JOURNAL CONVENTION (project/journal/README.md): the journal is a chronological LOG, not a live
  snapshot. Summary at the TOP; APPEND new entries at the BOTTOM (oldest->newest, never
  prepend); no stale "current state" block (that lives in project/status/project-status.md).

  Trivial commit? Bypass with:  SKIP_JOURNAL=1 git commit ...

MSG
exit 1

  "element": {
    "label": "span.vn-text",
    "text": "On your feet, then. I am Genemon, steward of this house, and",
    "selector": "div:nth-of-type(1) > div > p:nth-of-type(1) > span:nth-of-type(2)",
    "rect": {
      "x": 317,
      "y": 146,

{
  "name": "kami-kakushi",
  "version": "0.3.5",
  "private": true,
  "type": "module",
  "description": "Kamikakushi — a grounded, story-driven incremental RPG set in mid-Edo rural Japan. Built agentically.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsgo --noEmit && vite build",
    "build:itch": "npm run build && cd dist && zip -r ../kami-kakushi-itch.zip . && cd ..",
    "gh-pages": "bash src/scripts/gh-pages.sh",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "cloc": "cloc --exclude-ext=json --vcs=git .",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "gen:docs": "tsx src/scripts/gen-docs.ts",
    "gen:prd-regions": "tsx src/scripts/gen-prd-regions.ts",
    "gen:prd-regions:check": "tsx src/scripts/gen-prd-regions.ts --check",
    "pacing": "tsx src/scripts/pacing-report.ts",
    "pacing:check": "tsx src/scripts/pacing-report.ts --check",
    "playcheck": "tsx src/playcheck.ts",
    "playcheck:check": "tsx src/playcheck.ts --check",
    "prd:drift": "tsx src/scripts/prd-drift.ts",
    "links:check": "tsx src/scripts/check-md-links.ts",
    "checkpoint": "tsx src/scripts/checkpoint.ts",
    "checkpoint:check": "tsx src/scripts/checkpoint.ts --check",
    "verify": "tsx src/scripts/verify-run.ts",
    "verify:seq": "tsgo --noEmit && oxlint && oxfmt --check && vitest run && tsx src/scripts/verify-content.ts && tsx src/scripts/verify-prd.ts && tsx src/scripts/gen-docs.ts --check && tsx src/scripts/pacing-report.ts --check && tsx src/playcheck.ts --check && tsx src/scripts/check-md-links.ts",
    "verify:budget": "tsx src/scripts/verify-run.ts --budget"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.2",
    "@typescript/native-preview": "7.0.0-dev.20260704.1",
    "jsdom": "^25.0.1",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "playwright": "^1.61.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
